<script>
// ═══ TIME-OF-DAY SCROLL OBSERVER ═══
// Each section has a data-time attribute. As it enters viewport,
// the body class changes, triggering palette + mountain transitions.

const TIME_LABELS = {
  dawn:  'Dawn',
  day:   'Daybreak',
  dusk:  'Dusk',
  night: 'Nightfall'
};

const timeLabel = document.getElementById('time-label');
const sections = document.querySelectorAll('section[data-time]');

function setTime(time){
  document.body.classList.remove('t-dawn','t-day','t-dusk','t-night');
  document.body.classList.add('t-' + time);
  if(timeLabel) timeLabel.textContent = TIME_LABELS[time] || time;
}

// Use IntersectionObserver to detect which section is most visible
const obs = new IntersectionObserver((entries)=>{
  // Find the entry with the highest intersection ratio that's actually visible
  let topEntry = null;
  let topRatio = 0;
  entries.forEach(e=>{
    if(e.isIntersecting && e.intersectionRatio > topRatio){
      topRatio = e.intersectionRatio;
      topEntry = e;
    }
  });
  if(topEntry){
    const time = topEntry.target.dataset.time;
    if(time) setTime(time);
  }
},{
  threshold:[0.25,0.5,0.75],
  rootMargin:'-15% 0px -35% 0px'
});

sections.forEach(s=>obs.observe(s));

// Initialize with hero's time
setTime('dawn');

// Reveal animations
const revIo = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('in');
      revIo.unobserve(e.target);
    }
  });
},{threshold:0.07});
document.querySelectorAll('.rev').forEach(el=>revIo.observe(el));
</script>

</body>
</html>
